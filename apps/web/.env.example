# Postgres (shared with pad-core / pad-db)
DATABASE_URL=postgres://pad:password@localhost:5432/pad

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-random-secret

# Must match the OAuth callback redirect URI configured in Google Cloud Console:
# https://pad.app.zyx.tw/api/auth/callback/google
BETTER_AUTH_URL=https://pad.app.zyx.tw

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Single owner: any Google account that logs in AND has this email gets owner powers.
# Everyone else is a plain commenter.
OWNER_EMAIL=you@gmail.com
